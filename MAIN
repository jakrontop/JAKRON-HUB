local msg = loadstring(game:HttpGet('https://raw.githubusercontent.com/jakrontop/JAKRON-HUB/refs/heads/main/message_module'))()

msg.message("Loading Jakron Hub...", Color3.new(1,1,1), 5)

local Rayfield

local s,e = pcall(function()
 Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end)

if not s then
 msg.message("Failed to load Jakron Hub...", Color3.new(1,1,0),3)
else
 msg.message("Successfully loaded Jakron Hub!", Color3.new(0,1,0),3)
end