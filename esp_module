local module = {}

function module.billboard(obj,color,text)
   if obj:FindFirstChild("Jakron-UI") then
      obj["Jakron-UI"].TextLabel.TextColor3 = color
      return
   end

   local ui = Instance.new("BillboardGui",obj)
   ui.Name = "Jakron-UI"
   ui.AlwaysOnTop = true
   local label = Instance.new("TextLabel",ui)
   label.Size = UDim2.new(1,0,1,0)
   label.Text = text or "undefined"
   label.TextColor3 = color or Color3.new(1,1,1)
   label.TextScaled = true
   label.BackgroundTransparency = 1
   label.TextStrokeTransparency = 0
end

function module.highlight(obj,color)
   if obj:FindFirstChild("Jakron-ESP") then
      obj["Jakron-ESP"].FillColor = color
      return
   end

   local h = Instance.new("Highlight",obj)
   h.Name = "Jakron-ESP"
   h.FillColor = color or Color3.new(1,1,1)
   h.FillTransparency = 0
   return h
end

function module.esp(obj,color,text)
   module.billboard(obj,color,text)
   module.highlight(obj,color)
end

return module