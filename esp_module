local module = {}

function module.billboard(obj,color,text,name)
   name = name or "Jakron-UI"
   if obj:FindFirstChild(name) then
      obj[name].TextLabel.TextColor3 = color
obj[name].TextLabel.Text = text
      return
   end

   local ui = Instance.new("BillboardGui",obj)
   ui.Name = name
   ui.AlwaysOnTop = true
   ui.Size = UDim2.new(0,200,0,50)
   local label = Instance.new("TextLabel",ui)
   label.Size = UDim2.new(1,0,1,0)
   label.Text = text or "undefined"
   label.TextColor3 = color or Color3.new(1,1,1)
   label.TextScaled = true
   label.BackgroundTransparency = 1
   label.TextStrokeTransparency = 0
end

function module.highlight(obj,color,name)
   name = name or "Jakron-ESP"
   if obj:FindFirstChild(name) then
      obj[name].FillColor = color
      return
   end

   local h = Instance.new("Highlight",obj)
   h.Name = name
   h.FillColor = color or Color3.new(1,1,1)
   h.FillTransparency = 0
   return h
end

function module.esp(obj,color,text,name)
   module.billboard(obj,color,text,name)
   module.highlight(obj,color,name)
end

return module